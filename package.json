{
    "name": "@fabianbarua/pagopar-sdk",
    "publishConfig": {
        "access": "public"
    },
    "version": "0.1.1",
    "description": "SDK no oficial de Pagopar para Node.js / TypeScript. Cliente tipado para iniciar transacciones, consultar pedidos y manejar webhooks.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "migrations",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
        "clean": "rimraf dist",
        "prepublishOnly": "npm run clean && npm run build",
        "test": "node --test --import tsx ./tests/*.test.ts",
        "lint": "tsc --noEmit"
    },
    "keywords": [
        "pagopar",
        "paraguay",
        "payments",
        "pasarela",
        "pagos",
        "sdk",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "rimraf": "^5.0.5",
        "tsx": "^4.7.0",
        "typescript": "^5.4.0"
    },
    "repository": {
        "type": "git",
        "url": ""
    }
}